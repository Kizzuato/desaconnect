<%- include('partials/header') %>

<!-- TOP BAR dengan Hero, Cuaca & CTA -->
<div class="relative overflow-hidden" style="background: linear-gradient(135deg, #0d9488 0%, #0f766e 60%, #134e4a 100%);">
    <!-- Dekorasi lingkaran -->
    <div class="absolute top-0 right-0 w-72 h-72 rounded-full opacity-10" style="background:radial-gradient(circle, #fff 0%, transparent 70%); transform:translate(30%,-30%);"></div>
    <div class="absolute bottom-0 left-1/2 w-48 h-48 rounded-full opacity-5" style="background:#fff; transform:translate(-50%,50%);"></div>

    <div class="relative px-8 pt-8 pb-6 flex items-start justify-between gap-6">
        <div class="flex-1">
            <div class="flex items-center gap-4 flex-wrap mb-3">
                <div>
                    <p class="text-teal-200 text-sm font-medium tracking-wide uppercase mb-0.5">Selamat Datang di</p>
                    <h2 class="font-display text-3xl text-white leading-tight">Dashboard Pelayanan Desa</h2>
                </div>
                <!-- Widget Cuaca -->
                <div class="weather-widget px-4 py-2.5 flex items-center gap-3">
                    <div class="text-2xl">&#x26C5;</div>
                    <div>
                        <p class="text-white text-xs opacity-75 leading-none mb-0.5">Bandung</p>
                        <p class="text-white font-semibold text-sm leading-none">Cerah &bull; 28&deg;C</p>
                    </div>
                </div>
            </div>
            <p class="text-teal-100 text-sm opacity-80 max-w-lg">Pantau, laporkan, dan selesaikan permasalahan masyarakat desa secara transparan dan efisien.</p>
        </div>
        <a href="/lapor" class="btn-terra px-6 py-3 text-sm flex-shrink-0 self-start">
            + Buat Laporan Baru
        </a>
    </div>

    <!-- Ilustrasi Lanskap Desa (SVG Inline) -->
    <div class="px-8 pb-0 flex items-end" style="height:120px; overflow:hidden;">
        <svg viewBox="0 0 900 120" xmlns="http://www.w3.org/2000/svg" class="w-full" style="max-height:120px;" preserveAspectRatio="xMidYMax meet">
            <circle cx="800" cy="30" r="22" fill="#FDE68A" opacity="0.7"/>
            <polygon points="0,120 120,20 240,120" fill="#0f766e" opacity="0.5"/>
            <polygon points="100,120 260,10 420,120" fill="#134e4a" opacity="0.6"/>
            <polygon points="300,120 450,30 600,120" fill="#0f766e" opacity="0.45"/>
            <polygon points="500,120 680,40 860,120" fill="#134e4a" opacity="0.5"/>
            <rect x="0" y="90" width="900" height="30" fill="#065f46" opacity="0.55"/>
            <rect x="0" y="100" width="900" height="20" fill="#064e3b" opacity="0.55"/>
            <line x1="60" y1="90" x2="60" y2="120" stroke="#059669" stroke-width="1.5" opacity="0.5"/>
            <line x1="130" y1="90" x2="130" y2="120" stroke="#059669" stroke-width="1.5" opacity="0.5"/>
            <line x1="200" y1="90" x2="200" y2="120" stroke="#059669" stroke-width="1.5" opacity="0.5"/>
            <line x1="270" y1="90" x2="270" y2="120" stroke="#059669" stroke-width="1.5" opacity="0.5"/>
            <line x1="340" y1="90" x2="340" y2="120" stroke="#059669" stroke-width="1.5" opacity="0.5"/>
            <line x1="410" y1="90" x2="410" y2="120" stroke="#059669" stroke-width="1.5" opacity="0.5"/>
            <rect x="380" y="65" width="140" height="55" fill="#92400e" opacity="0.8"/>
            <polygon points="360,65 520,65 440,30" fill="#78350f" opacity="0.9"/>
            <rect x="420" y="80" width="40" height="40" fill="#451a03" opacity="0.8"/>
            <line x1="460" y1="30" x2="460" y2="5" stroke="#fff" stroke-width="1.5" opacity="0.6"/>
            <polygon points="460,5 478,11 460,17" fill="#EF4444" opacity="0.8"/>
            <line x1="300" y1="120" x2="300" y2="55" stroke="#064e3b" stroke-width="4"/>
            <ellipse cx="300" cy="52" rx="20" ry="14" fill="#065f46" opacity="0.9"/>
            <line x1="590" y1="120" x2="590" y2="60" stroke="#064e3b" stroke-width="4"/>
            <ellipse cx="590" cy="57" rx="18" ry="12" fill="#065f46" opacity="0.9"/>
            <line x1="700" y1="120" x2="700" y2="50" stroke="#064e3b" stroke-width="4"/>
            <ellipse cx="700" cy="47" rx="22" ry="15" fill="#065f46" opacity="0.9"/>
        </svg>
    </div>
</div>

<!-- STAT CARDS -->
<div class="px-8 py-6">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
        <!-- Pending -->
        <div class="card stat-pending p-6">
            <div class="flex items-center justify-between mb-3">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background:#fffbeb; border: 1.5px solid #fcd34d;">
                    <span class="text-xl">&#x23F3;</span>
                </div>
                <span class="text-xs font-semibold text-amber-600 bg-amber-50 border border-amber-200 px-2.5 py-1 rounded-full">Menunggu</span>
            </div>
            <h3 class="font-sans text-gray-500 text-sm font-medium">Laporan Pending</h3>
            <p class="font-display text-4xl text-gray-800 mt-1"><%= stats.Pending || 0 %></p>
        </div>
        <!-- Proses -->
        <div class="card stat-proses p-6">
            <div class="flex items-center justify-between mb-3">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background:#f0fdfa; border: 1.5px solid #5eead4;">
                    <span class="text-xl">&#x1F504;</span>
                </div>
                <span class="text-xs font-semibold text-teal-700 bg-teal-50 border border-teal-200 px-2.5 py-1 rounded-full">Aktif</span>
            </div>
            <h3 class="font-sans text-gray-500 text-sm font-medium">Sedang Diproses</h3>
            <p class="font-display text-4xl text-gray-800 mt-1"><%= stats.Proses || 0 %></p>
        </div>
        <!-- Selesai -->
        <div class="card stat-selesai p-6">
            <div class="flex items-center justify-between mb-3">
                <div class="w-11 h-11 rounded-xl flex items-center justify-center" style="background:#f0fdf4; border: 1.5px solid #86efac;">
                    <span class="text-xl">&#x2705;</span>
                </div>
                <span class="text-xs font-semibold text-green-700 bg-green-50 border border-green-200 px-2.5 py-1 rounded-full">Tuntas</span>
            </div>
            <h3 class="font-sans text-gray-500 text-sm font-medium">Laporan Selesai</h3>
            <p class="font-display text-4xl text-gray-800 mt-1"><%= stats.Selesai || 0 %></p>
        </div>
    </div>

    <!-- TABEL LAPORAN (full-width) -->
    <div class="card p-6">
        <div class="flex items-center justify-between mb-5">
            <h3 class="font-serif text-xl text-gray-800">Laporan Terbaru</h3>
            <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
                <a href="/admin" class="text-sm text-teal-600 hover:text-teal-800 font-medium hover:underline">Lihat semua &rarr;</a>
            <% } else { %>
                <a href="/pengaduan-saya" class="text-sm text-teal-600 hover:text-teal-800 font-medium hover:underline">Lihat semua &rarr;</a>
            <% } %>
        </div>
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b border-gray-100">
                        <th class="pb-3 px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Pelapor</th>
                        <th class="pb-3 px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Judul Laporan</th>
                        <th class="pb-3 px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Tanggal</th>
                        <th class="pb-3 px-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Status</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    <% if (reports && reports.length > 0) { %>
                        <% reports.forEach(function(report) { %>
                            <tr>
                                <td class="py-3.5 px-2">
                                    <div class="flex items-center gap-2.5">
                                        <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold text-white flex-shrink-0" style="background: linear-gradient(135deg, #0d9488, #0f766e);">
                                            <%= report.nama_pelapor.charAt(0).toUpperCase() %>
                                        </div>
                                        <span class="text-gray-700 font-medium text-sm"><%= report.nama_pelapor %></span>
                                    </div>
                                </td>
                                <td class="py-3.5 px-2 text-gray-600 text-sm"><%= report.judul %></td>
                                <td class="py-3.5 px-2 text-gray-400 text-xs"><%= formatDate(report.created_at) %></td>
                                <td class="py-3.5 px-2">
                                    <% if (report.status === 'Pending') { %>
                                        <span class="badge-pending px-3 py-1.5 rounded-full text-xs font-semibold inline-flex items-center gap-1.5">
                                            <span class="w-1.5 h-1.5 rounded-full bg-amber-400 inline-block"></span>Pending
                                        </span>
                                    <% } else if (report.status === 'Proses') { %>
                                        <span class="badge-proses px-3 py-1.5 rounded-full text-xs font-semibold inline-flex items-center gap-1.5">
                                            <span class="w-1.5 h-1.5 rounded-full bg-teal-400 inline-block"></span>Proses
                                        </span>
                                    <% } else if (report.status === 'Selesai') { %>
                                        <span class="badge-selesai px-3 py-1.5 rounded-full text-xs font-semibold inline-flex items-center gap-1.5">
                                            <span class="w-1.5 h-1.5 rounded-full bg-green-500 inline-block"></span>Selesai
                                        </span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    <% } else { %>
                        <tr>
                            <td colspan="4" class="py-10 text-center">
                                <div class="text-4xl mb-2">&#x1F4CB;</div>
                                <p class="text-gray-400 text-sm">Belum ada laporan masuk.</p>
                                <a href="/lapor" class="text-teal-600 text-sm hover:underline mt-1 inline-block">Buat laporan pertama &rarr;</a>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</div>

<%- include('partials/footer') %>

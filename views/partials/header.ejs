<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>DesaConnect — Portal Pelayanan Publik</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Lora:wght@400;500;600;700&family=Playfair+Display:wght@700;800&family=Poppins:wght@300;400;500;600&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        teal:   { DEFAULT: '#0d9488', light: '#ccfbf1', dark: '#0f766e', faint: '#f0fdfa' },
                        terra:  { DEFAULT: '#E2725B', dark: '#c85a44', light: '#fdf0ee' },
                        forest: { DEFAULT: '#228B22', light: '#dcfce7' },
                        sand:   { DEFAULT: '#F5F0E8' },
                    },
                    fontFamily: {
                        serif:   ['Lora', 'Georgia', 'serif'],
                        display: ['Playfair Display', 'Georgia', 'serif'],
                        sans:    ['Poppins', 'sans-serif'],
                    },
                }
            }
        }
    </script>
    <style>
        *, *::before, *::after { box-sizing: border-box; }
        body { font-family: 'Poppins', sans-serif; background: #F5F0E8; min-height: 100vh; }
        h1,h2,h3,h4 { font-family: 'Lora', Georgia, serif; }

        .sidebar { background: linear-gradient(180deg, #0d9488 0%, #0f766e 100%); }
        .nav-link { color: rgba(255,255,255,0.7); border-radius: 1rem; transition: all 0.25s; padding: 0.65rem 1.1rem; display: flex; align-items: center; gap: 0.6rem; font-weight: 500; font-size: 0.9rem; }
        .nav-link:hover { background: rgba(255,255,255,0.15); color: #fff; transform: translateX(3px); }
        .nav-link.active { background: rgba(255,255,255,0.22); color: #fff; box-shadow: inset 0 0 0 1.5px rgba(255,255,255,0.3); }

        .card { background: #fff; border-radius: 1.25rem; box-shadow: 0 4px 24px 0 rgba(13,148,136,0.07), 0 1px 4px 0 rgba(0,0,0,0.04); transition: transform 0.22s, box-shadow 0.22s; }
        .card:hover { transform: translateY(-3px); box-shadow: 0 10px 36px 0 rgba(13,148,136,0.14), 0 2px 8px 0 rgba(0,0,0,0.06); }
        .card-static { background: #fff; border-radius: 1.25rem; box-shadow: 0 4px 24px 0 rgba(13,148,136,0.07); }

        .stat-pending { background: linear-gradient(135deg, #fffbeb 0%, #fff 100%); border-top: 4px solid #f59e0b; }
        .stat-proses  { background: linear-gradient(135deg, #f0fdfa 0%, #fff 100%); border-top: 4px solid #0d9488; }
        .stat-selesai { background: linear-gradient(135deg, #f0fdf4 0%, #fff 100%); border-top: 4px solid #228B22; }

        .badge-pending { background:#fffbeb; color:#92400e; border:1px solid #fcd34d; }
        .badge-proses  { background:#f0fdfa; color:#0f766e; border:1px solid #5eead4; }
        .badge-selesai { background:#f0fdf4; color:#166534; border:1px solid #86efac; }

        .btn-terra { background:#E2725B; color:#fff; border-radius:0.9rem; font-weight:600; transition:all 0.2s; box-shadow:0 4px 14px 0 rgba(226,114,91,0.35); display:inline-block; text-align:center; }
        .btn-terra:hover { background:#c85a44; transform:translateY(-2px); box-shadow:0 8px 20px 0 rgba(226,114,91,0.45); }
        .btn-teal { background:#0d9488; color:#fff; border-radius:0.9rem; font-weight:600; transition:all 0.2s; box-shadow:0 4px 14px 0 rgba(13,148,136,0.3); display:inline-block; text-align:center; }
        .btn-teal:hover { background:#0f766e; transform:translateY(-2px); }

        .weather-widget { background:rgba(255,255,255,0.18); backdrop-filter:blur(6px); border:1px solid rgba(255,255,255,0.3); border-radius:0.85rem; }
        tbody tr { transition: background 0.15s; }
        tbody tr:hover { background: #f0fdfa; }

        .form-input { width:100%; padding:0.75rem 1rem; border-radius:0.75rem; border:1px solid #e5e7eb; outline:none; font-family:'Poppins',sans-serif; color:#374151; background:#f9fafb; transition:all 0.2s; }
        .form-input:focus { border-color:#0d9488; box-shadow:0 0 0 3px rgba(13,148,136,0.15); background:#fff; }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <% if (!locals.hideSidebar) { %>
    <!-- SIDEBAR -->
    <aside class="sidebar w-60 flex-shrink-0 flex flex-col shadow-xl">
        <div class="px-5 pt-7 pb-5">
            <div class="flex items-center gap-2.5 mb-1">
                <div class="w-8 h-8 bg-white rounded-xl flex items-center justify-center shadow flex-shrink-0">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg>
                </div>
                <div>
                    <h1 class="text-white font-display text-lg leading-none">DesaConnect</h1>
                    <p class="text-white text-xs opacity-50">Portal Pelayanan Publik</p>
                </div>
            </div>
        </div>

        <nav class="flex-1 px-3 space-y-0.5">
            <p class="text-xs uppercase tracking-widest text-white opacity-30 px-3 pb-1 pt-2">Menu</p>
            <a href="/" class="nav-link <%= typeof page !== 'undefined' && page === 'home' ? 'active' : '' %>">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/></svg>
                Dashboard
            </a>
            <% if (typeof user === 'undefined' || !user || user.role !== 'admin') { %>
            <a href="/lapor" class="nav-link <%= typeof page !== 'undefined' && page === 'lapor' ? 'active' : '' %>">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
                Buat Laporan
            </a>
            <% } %>
            <% if (typeof user !== 'undefined' && user && user.role !== 'admin') { %>
            <a href="/pengaduan-saya" class="nav-link <%= typeof page !== 'undefined' && page === 'pengaduan-saya' ? 'active' : '' %>">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
                Pengaduan Saya
            </a>
            <% } %>
            <% if (typeof user !== 'undefined' && user && user.role === 'admin') { %>
            <a href="/admin" class="nav-link <%= typeof page !== 'undefined' && page === 'admin' ? 'active' : '' %>">
                <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg>
                Admin Panel
            </a>
            <% } %>
        </nav>

        <!-- User Info / Auth -->
        <div class="px-3 pb-5 pt-3 border-t border-white border-opacity-10">
            <% if (typeof user !== 'undefined' && user) { %>
                <div class="flex items-center gap-2.5 mb-3 px-2">
                    <div class="w-8 h-8 rounded-full flex items-center justify-center text-sm font-bold text-white flex-shrink-0" style="background:rgba(255,255,255,0.25);">
                        <%= user.nama.charAt(0).toUpperCase() %>
                    </div>
                    <div class="min-w-0">
                        <p class="text-white text-xs font-semibold truncate"><%= user.nama %></p>
                        <p class="text-white text-xs opacity-50 truncate"><%= user.email %></p>
                    </div>
                </div>
                <form action="/logout" method="POST">
                    <button type="submit" class="w-full text-left nav-link opacity-70 hover:opacity-100">
                        <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                        Keluar
                    </button>
                </form>
            <% } else { %>
                <a href="/login" class="nav-link">
                    <svg width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/></svg>
                    Masuk / Daftar
                </a>
            <% } %>
        </div>
    </aside>
    <% } %>

    <!-- MAIN CONTENT -->
    <main class="<%= locals.hideSidebar ? 'w-full h-full overflow-y-auto' : 'flex-1 overflow-y-auto' %>">

<%- include('partials/header') %>

<!-- TOP BAR -->
<div class="relative overflow-hidden" style="background:linear-gradient(135deg,#0d9488 0%,#0f766e 60%,#134e4a 100%);">
    <div class="absolute top-0 right-0 w-64 h-64 rounded-full opacity-10" style="background:radial-gradient(circle,#fff 0%,transparent 70%);transform:translate(30%,-30%);"></div>
    <div class="relative px-8 py-8">
        <a href="/pengaduan-saya" class="text-teal-200 text-sm hover:text-white transition-colors inline-flex items-center gap-1 mb-2">
            &larr; Kembali ke Daftar
        </a>
        <h2 class="font-display text-3xl text-white">Detail Laporan #<%= report.id %></h2>
        <p class="text-teal-100 text-sm opacity-80 mt-1">Dikirim pada <%= formatDate(report.created_at) %></p>
    </div>
</div>

<div class="px-8 py-6 max-w-3xl mx-auto">
    <div class="card-static p-8 space-y-6">

        <!-- Status & Progress -->
        <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Status Terkini</p>
            <% if (report.status === 'Pending') { %>
                <span class="badge-pending px-4 py-2 rounded-full text-sm font-semibold inline-flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-amber-400 inline-block animate-pulse"></span>Diterima &bull; Menunggu Tindak Lanjut
                </span>
            <% } else if (report.status === 'Proses') { %>
                <span class="badge-proses px-4 py-2 rounded-full text-sm font-semibold inline-flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-teal-400 inline-block animate-pulse"></span>Sedang Diproses oleh Petugas
                </span>
            <% } else if (report.status === 'Selesai') { %>
                <span class="badge-selesai px-4 py-2 rounded-full text-sm font-semibold inline-flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-green-500 inline-block"></span>Selesai &bull; Laporan Telah Ditangani
                </span>
            <% } %>
        </div>

        <hr class="border-gray-100">

        <!-- Detail Info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Nama Pelapor</p>
                <p class="text-gray-800 font-medium"><%= report.nama_pelapor %></p>
            </div>
            <div>
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Tanggal Laporan</p>
                <p class="text-gray-800 font-medium"><%= formatDate(report.created_at) %></p>
            </div>
            <div class="md:col-span-2">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Judul Laporan</p>
                <p class="text-gray-800 font-semibold text-lg font-serif"><%= report.judul %></p>
            </div>
            <div class="md:col-span-2">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1">Deskripsi</p>
                <p class="text-gray-700 leading-relaxed"><%= report.deskripsi %></p>
            </div>
        </div>

        <% if (report.foto_url) { %>
        <hr class="border-gray-100">
        <div>
            <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-3">Bukti Foto</p>
            <a href="<%= report.foto_url %>" target="_blank">
                <img src="<%= report.foto_url %>" alt="Bukti laporan" class="rounded-2xl max-h-80 object-cover shadow-md hover:shadow-lg transition-shadow border border-gray-100">
            </a>
            <p class="text-xs text-gray-400 mt-2">Klik gambar untuk memperbesar &bull; Disimpan via S3 + CloudFront</p>
        </div>
        <% } %>

        <hr class="border-gray-100">
        <a href="/pengaduan-saya" class="inline-flex items-center gap-2 text-teal-600 font-semibold hover:underline text-sm">
            &larr; Kembali ke Semua Pengaduan
        </a>
    </div>
</div>

<%- include('partials/footer') %>
